# Public env vars (safe to expose in the browser)
# Copy to .env.local for local dev, or set in Netlify → Project configuration → Environment variables.

NEXT_PUBLIC_SITE_URL=https://halfabilagency.netlify.app

# Stripe Payment Links — create in Stripe Dashboard → Payment Links
